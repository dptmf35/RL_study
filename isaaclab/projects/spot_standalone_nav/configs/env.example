# Copy this file to env.local and edit values.

# Isaac Sim standalone root (contains python.sh)
export ISAACSIM_ROOT="$HOME/isaac-sim-standalone-5.0.0-linux-x86_64"

# IsaacLab root
export ISAACLAB_ROOT="$HOME/IsaacLab"

# Low-level Spot walk policy (JIT)
export SPOT_LL_POLICY="$ISAACLAB_ROOT/logs/rsl_rl/spot_flat/<run>/exported/policy.pt"

# High-level Spot navigation checkpoint
# Can be raw model_XXXX.pt or exported JIT policy.pt
export SPOT_NAV_CKPT="$ISAACLAB_ROOT/logs/rsl_rl/spot_navigation/<run>/model_3399.pt"

# Optional: full warehouse USD path override
# export ISAACLAB_SPOT_FULL_WAREHOUSE_USD_PATH="omniverse://.../full_warehouse.usd"
